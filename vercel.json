{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.php" },
    { "source": "/about", "destination": "/about.php" },
    { "source": "/product", "destination": "/product.php" },
    { "source": "/solution", "destination": "/solution.php" },
    { "source": "/comparison", "destination": "/comparison.php" },
    { "source": "/contact", "destination": "/contact.php" },
    { "source": "/privacy", "destination": "/privacy.php" }
  ]
}