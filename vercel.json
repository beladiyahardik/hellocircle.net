{
  "version": 2,
  "builds": [
    { "src": "*.php", "use": "@vercel/php" }
  ],
  "routes": [
    { "src": "/$", "dest": "/index.php" },
    { "src": "/about/?$", "dest": "/about.php" },
    { "src": "/product/?$", "dest": "/product.php" },
    { "src": "/solution/?$", "dest": "/solution.php" },
    { "src": "/comparison/?$", "dest": "/comparison.php" },
    { "src": "/contact/?$", "dest": "/contact.php" },
    { "src": "/privacy/?$", "dest": "/privacy.php" },
    { "src": "/(.*)\\.php$", "dest": "/$1.php" }
  ]
}